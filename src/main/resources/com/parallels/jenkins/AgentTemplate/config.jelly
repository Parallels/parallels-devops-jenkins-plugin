<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form" xmlns:c="/lib/credentials">
    <f:entry title="Template Label" field="templateLabel">
        <f:textbox />
    </f:entry>
    <f:entry title="VM User" field="vmUser">
        <f:textbox default="parallels" />
    </f:entry>

    <f:entry title="VM Provisioning Mode" field="provisioningMode">
        <!-- Clone option only shown in HOST mode -->
        <j:if test="${instance == null or instance.provisioningMode != 'CATALOG'}">
            <f:radioBlock name="provisioningMode" value="CLONE"
                          title="Clone existing VM"
                          checked="${instance == null || instance.provisioningMode == 'CLONE' || instance.provisioningMode == null}">
                <f:entry title="Base VM Name" field="baseVmName">
                    <f:textbox />
                </f:entry>
            </f:radioBlock>
        </j:if>
        <f:radioBlock name="provisioningMode" value="CATALOG"
                      title="Create from catalog"
                      checked="${instance != null and instance.provisioningMode == 'CATALOG'}">
            <f:entry title="Architecture" field="architecture">
                <f:select />
            </f:entry>
            <f:entry title="Catalog ID" field="catalogId">
                <f:textbox placeholder="e.g. EMPTY-VM" />
            </f:entry>
            <f:entry title="Catalog Version" field="catalogVersion">
                <f:textbox default="latest" />
            </f:entry>
            <f:entry title="Catalog URL" field="catalogUrl">
                <f:textbox placeholder="https://devops-catalog.example.com" />
            </f:entry>
            <f:entry title="Catalog Credentials" field="catalogCredentialsId">
                <c:select />
            </f:entry>
        </f:radioBlock>
    </f:entry>

    <f:entry title="Number of Executors" field="numExecutors">
        <f:number default="1" min="1" />
    </f:entry>
</j:jelly>
